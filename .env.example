# Supabase configuration for I'm Realtor (private beta)
#
# Copy this file to .env.local and fill in real values from your Supabase
# project settings (Project Settings > API). Never commit .env.local.
#
# The app is designed to build and run even if these are left blank —
# see src/lib/supabase/status.ts. Pages fall back to mock data until
# Supabase is configured.

# Public Supabase project URL. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Public "anon" key. Safe to expose to the browser — it can only do what
# Row Level Security (see src/lib/db/rls.sql) allows for anonymous/authenticated
# users. It must NOT be treated as a secret bypass key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. This key BYPASSES Row Level Security entirely.
# - NEVER prefix this with NEXT_PUBLIC_.
# - NEVER import it into a Client Component or expose it to the browser.
# - Only read it from server-only code (see src/lib/supabase/admin.ts).
SUPABASE_SERVICE_ROLE_KEY=

# Base URL of this app, used for building absolute links (e.g. emails, redirects).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# In production (e.g. Vercel), set these same variable names in
# Project Settings > Environment Variables instead of committing a .env file.
